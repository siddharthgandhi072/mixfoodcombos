// storage.rules
//
// Controls who can upload/delete the PNG images attached to blog posts.
// Deploy by pasting into: Firebase console > Storage > Rules > paste >
// Publish. See docs/SETUP.md.

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Images live at post-images/<uploader's uid>/<filename>.png so we can
    // cheaply check "does this uid match the folder" for write access.
    match /post-images/{uid}/{fileName} {
      allow read: if true; // blog images are public, like the posts themselves

      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType == 'image/png';

      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
